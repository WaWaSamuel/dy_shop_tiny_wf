# Application
APP_NAME=douyin-shop-automation
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://douyin:douyin_secret@db:5432/douyin_shop
POSTGRES_USER=douyin
POSTGRES_PASSWORD=douyin_secret
POSTGRES_DB=douyin_shop

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Douyin Open API
DOUYIN_APP_KEY=your-app-key
DOUYIN_APP_SECRET=your-app-secret
DOUYIN_SHOP_ID=your-shop-id

# Logging
LOG_LEVEL=INFO
