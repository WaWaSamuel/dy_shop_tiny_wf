# ==================== App ====================
APP_NAME=Personal Studio
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ==================== Security / JWT ====================
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== PostgreSQL ====================
# Write (primary)
DATABASE_URL=postgresql+asyncpg://studio:studio_password_2024@localhost:5432/studio_main
# Read replica (leave empty to fall back to primary)
DATABASE_READ_URL=
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ==================== Celery ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# ==================== Provider integrations ====================
PROVIDER_TIMEOUT=30
PROVIDER_RETRY_COUNT=3

# ==================== AI / Creative ====================
OPENAI_API_KEY=
STABILITY_API_KEY=

# ==================== Feishu IM Bot ====================
FEISHU_BOT_ENABLED=true
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_DOMAIN=https://open.feishu.cn
# Primary push target. Use the recipient open_id captured from Feishu logs.
FEISHU_BOT_TARGET_OPEN_ID=
# Optional business owner_id. Only used by order commands inside the bot.
FEISHU_BOT_OWNER_ID=
# Optional group fallback when target open_id is not set.
FEISHU_BOT_DEFAULT_CHAT_ID=
# Optional: shared token for calling the server-side push API.
FEISHU_BOT_PUSH_TOKEN=

# ==================== News aggregation ====================
# Configure followed public-account mirrors via RSS/Atom/JSON feeds.
# Example:
# NEWS_SOURCE_CONFIG=[{"id":"latepost","name":"晚点LatePost","feed_url":"https://your-rsshub.example.com/wechat/mp/<biz>","homepage_url":"https://mp.weixin.qq.com/"}]
NEWS_SOURCE_CONFIG=
NEWS_DIGEST_TIMEZONE=Asia/Shanghai
NEWS_DIGEST_WINDOW_START_HOUR=21
NEWS_DIGEST_WINDOW_END_HOUR=9
NEWS_DIGEST_MAX_ARTICLES=24
NEWS_DIGEST_MAX_ITEMS_PER_SOURCE=8
NEWS_DIGEST_REQUEST_TIMEOUT_SECONDS=20
NEWS_DIGEST_CACHE_TTL_SECONDS=43200
NEWS_DIGEST_USER_AGENT=DYShop-NewsAggregator/1.0
NEWS_DIGEST_ARTICLE_TEXT_LIMIT=1600
